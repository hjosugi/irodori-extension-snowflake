{
  "$schema": "https://irodori.dev/schemas/irodori.extension.schema.json",
  "manifestVersion": 1,
  "id": "irodori.snowflake",
  "name": "Snowflake Connector",
  "version": "0.1.0",
  "publisher": "irodori",
  "description": "Snowflake Connector contributes the Snowflake database connector through the native connector ABI.",
  "license": "MIT OR 0BSD",
  "repository": "https://github.com/hjosugi/irodori-extension-snowflake",
  "apiVersion": "0.1",
  "runtime": "native",
  "entry": "dist/native",
  "permissions": [
    "connections:read",
    "connections:write",
    "queries:run",
    "metadata:read",
    "native",
    "connectors"
  ],
  "contributes": {
    "connectors": [
      {
        "id": "snowflake.connector",
        "engine": "snowflake",
        "label": "Snowflake",
        "aliases": [
          "snowflake",
          "Snowflake"
        ],
        "defaultPort": 443,
        "wire": "snowflake",
        "module": "snowflake.driver",
        "features": [
          "metadata",
          "sql",
          "streaming",
          "explain"
        ],
        "connection": {
          "schemaVersion": 1,
          "inferEnvironmentFrom": [
            "name",
            "id",
            "host",
            "database",
            "url"
          ],
          "compatibility": {
            "addsRequiredProfileFields": false,
            "acceptsExistingProfiles": true
          },
          "defaults": {
            "engine": "snowflake",
            "wire": "snowflake",
            "port": 443,
            "readOnly": false
          },
          "endpoint": {
            "modes": [
              "hostPort",
              "connectionString"
            ],
            "defaultPort": 443,
            "fields": [
              {
                "id": "host",
                "label": "Host",
                "type": "string",
                "profileField": "host",
                "required": true
              },
              {
                "id": "port",
                "label": "Port",
                "type": "number",
                "profileField": "port",
                "default": 443
              },
              {
                "id": "database",
                "label": "Database",
                "type": "string",
                "profileField": "database"
              }
            ]
          },
          "profileFields": [
            {
              "id": "id",
              "label": "Connection ID",
              "type": "string",
              "profileField": "id",
              "required": true
            },
            {
              "id": "url",
              "label": "Connection URL or DSN",
              "type": "uri",
              "profileField": "url"
            },
            {
              "id": "user",
              "label": "User",
              "type": "string",
              "profileField": "user"
            },
            {
              "id": "host",
              "label": "Host",
              "type": "string",
              "profileField": "host",
              "required": true
            },
            {
              "id": "port",
              "label": "Port",
              "type": "number",
              "profileField": "port",
              "default": 443
            },
            {
              "id": "database",
              "label": "Database",
              "type": "string",
              "profileField": "database"
            },
            {
              "id": "readOnly",
              "label": "Read-only connection",
              "type": "boolean",
              "profileField": "readOnly",
              "default": false
            },
            {
              "id": "options",
              "label": "Driver options",
              "type": "map",
              "profileField": "options"
            }
          ],
          "authMethods": [
            {
              "id": "none",
              "label": "No authentication",
              "kind": "none",
              "secretPurposes": [],
              "fields": []
            },
            {
              "id": "connectionString",
              "label": "Connection string / DSN",
              "kind": "connectionString",
              "secretPurposes": [],
              "fields": [
                {
                  "id": "url",
                  "label": "Connection URL or DSN",
                  "type": "uri",
                  "profileField": "url",
                  "required": true
                }
              ]
            },
            {
              "id": "userPassword",
              "label": "User/password",
              "kind": "userPassword",
              "secretPurposes": [
                "password"
              ],
              "fields": [
                {
                  "id": "user",
                  "label": "User",
                  "type": "string",
                  "profileField": "user"
                },
                {
                  "id": "password",
                  "label": "Password",
                  "type": "secret",
                  "secretPurpose": "password",
                  "profileField": "password"
                }
              ]
            },
            {
              "id": "snowflakeKeyPair",
              "label": "Key-pair JWT",
              "kind": "privateKey",
              "secretPurposes": [
                "privateKey",
                "privateKeyPassphrase"
              ],
              "fields": [
                {
                  "id": "user",
                  "label": "User or client email",
                  "type": "string",
                  "profileField": "user"
                },
                {
                  "id": "privateKey",
                  "label": "Private key",
                  "type": "pem",
                  "secretPurpose": "privateKey"
                },
                {
                  "id": "privateKeyPassphrase",
                  "label": "Private key passphrase",
                  "type": "secret",
                  "secretPurpose": "privateKeyPassphrase"
                }
              ]
            },
            {
              "id": "oauth2",
              "label": "OAuth 2.0",
              "kind": "oauth2",
              "secretPurposes": [
                "token"
              ],
              "fields": [
                {
                  "id": "accessToken",
                  "label": "Access token",
                  "type": "secret",
                  "secretPurpose": "token"
                },
                {
                  "id": "refreshToken",
                  "label": "Refresh token",
                  "type": "secret",
                  "secretPurpose": "token"
                },
                {
                  "id": "clientId",
                  "label": "Client ID",
                  "type": "string"
                },
                {
                  "id": "clientSecret",
                  "label": "Client secret",
                  "type": "secret",
                  "secretPurpose": "token"
                }
              ]
            },
            {
              "id": "snowflakeSessionToken",
              "label": "Session token",
              "kind": "token",
              "secretPurposes": [
                "token"
              ],
              "fields": [
                {
                  "id": "token",
                  "label": "Token",
                  "type": "secret",
                  "secretPurpose": "token"
                }
              ]
            },
            {
              "id": "browserSso",
              "label": "Browser SSO",
              "kind": "browserSso",
              "secretPurposes": [
                "token"
              ],
              "fields": []
            },
            {
              "id": "saml",
              "label": "SAML SSO",
              "kind": "saml",
              "secretPurposes": [
                "token"
              ],
              "fields": [
                {
                  "id": "idpUrl",
                  "label": "Identity provider URL",
                  "type": "uri"
                },
                {
                  "id": "assertion",
                  "label": "SAML assertion",
                  "type": "secret",
                  "secretPurpose": "token"
                }
              ]
            },
            {
              "id": "externalBrowser",
              "label": "External browser",
              "kind": "browserSso",
              "secretPurposes": [
                "token"
              ],
              "fields": []
            },
            {
              "id": "customDriverOptions",
              "label": "Custom driver options",
              "kind": "custom",
              "secretPurposes": [
                "password",
                "token",
                "privateKey",
                "privateKeyPassphrase"
              ],
              "fields": [
                {
                  "id": "options",
                  "label": "Driver options",
                  "type": "map",
                  "profileField": "options"
                }
              ]
            }
          ],
          "secretPurposes": [
            "password",
            "privateKey",
            "privateKeyPassphrase",
            "token"
          ],
          "tls": {
            "supported": true,
            "requiredByDefault": true,
            "modes": [
              "disable",
              "prefer",
              "require",
              "verifyCa",
              "verifyFull",
              "clientCertificate"
            ],
            "fields": [
              {
                "id": "caCertificate",
                "label": "CA certificate",
                "type": "pem"
              },
              {
                "id": "clientCertificate",
                "label": "Client certificate",
                "type": "pem"
              },
              {
                "id": "clientPrivateKey",
                "label": "Client private key",
                "type": "pem",
                "secretPurpose": "privateKey"
              }
            ]
          },
          "transports": [
            "direct",
            "sshTunnel",
            "socks5Proxy",
            "httpConnectProxy",
            "proxyChain"
          ],
          "optionNamespaces": [
            "profile.options",
            "driver",
            "tls",
            "network",
            "snowflake"
          ],
          "customDriverOptions": true
        }
      }
    ]
  },
  "capabilities": {
    "nativeModules": [
      {
        "id": "snowflake.driver",
        "path": "dist/native",
        "platforms": [
          "windowsX64",
          "windowsArm64",
          "macosX64",
          "macosArm64",
          "linuxX64",
          "linuxArm64"
        ]
      }
    ]
  },
  "dev": {
    "watch": [
      "src",
      "connector.config.json",
      "irodori.extension.json"
    ]
  }
}
